<Window x:Class="TotpApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:TotpApp.Converters"
        Title="TOTP認証アプリ"
        Width="420" Height="600"
        MinWidth="360">

    <Window.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:ExpiringSoonToBrushConverter x:Key="ExpiringSoonToBrushConverter" />
        <conv:CopiedToLabelConverter x:Key="CopiedToLabelConverter" />
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button Content="画面スキャン(QRコード読み取り)"
                    Padding="12,6"
                    Command="{Binding ScanCommand}"
                    IsEnabled="{Binding IsScanning, Converter={StaticResource InverseBoolConverter}}" />
            <ProgressBar Width="20" Height="20" Margin="12,0,0,0"
                         IsIndeterminate="True"
                         Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibilityConverter}}" />
        </StackPanel>

        <TextBlock Grid.Row="1" Margin="0,8,0,0"
                   Text="{Binding StatusMessage}"
                   Foreground="Gray" />

        <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Accounts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#F3F3F3"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Issuer}" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Text="{Binding AccountName}" Foreground="Gray" FontSize="12" Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding CurrentCode}" FontSize="32" FontFamily="Consolas" Margin="0,4,0,4" />
                                    <ProgressBar Value="{Binding ProgressFraction}"
                                                 Maximum="1"
                                                 Height="4"
                                                 Foreground="{Binding IsExpiringSoon, Converter={StaticResource ExpiringSoonToBrushConverter}}" />
                                </StackPanel>

                                <Button Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Margin="16,0,0,0"
                                        Padding="10,6"
                                        Command="{Binding CopyCommand}"
                                        Content="{Binding WasRecentlyCopied, Converter={StaticResource CopiedToLabelConverter}}" />

                                <Button Grid.Column="2"
                                        VerticalAlignment="Center"
                                        Margin="8,0,0,0"
                                        Padding="10,6"
                                        Command="{Binding DataContext.DeleteAccountCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"
                                        Content="削除"
                                        Background="#FFE5E5"
                                        BorderBrush="#FFC1C1"
                                        Foreground="#D32F2F" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
