<Window x:Class="TotpApp.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="アカウントの引き継ぎ・バックアップ"
        Width="380" Height="490"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F5F7">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header -->
            <RowDefinition Height="*" />    <!-- QR Code Container -->
            <RowDefinition Height="Auto" /> <!-- URI Text Box & Copy Button -->
            <RowDefinition Height="Auto" /> <!-- Close Button -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="他アプリへの引き継ぎ・バックアップ" 
                       FontWeight="Bold" 
                       FontSize="16" 
                       Foreground="#1D1D1F" 
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="AccountLabel" 
                       Text="Issuer (AccountName)" 
                       FontSize="13" 
                       Foreground="#86868B" 
                       HorizontalAlignment="Center" 
                       Margin="0,4,0,0" 
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- QR Code Container -->
        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="12" 
                Padding="16" 
                BorderBrush="#E5E5EA" 
                BorderThickness="1"
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                Width="240" Height="240">
            <Grid>
                <Image x:Name="QrCodeImage" Stretch="Uniform" />
            </Grid>
        </Border>

        <!-- URI Text Box & Copy Button -->
        <StackPanel Grid.Row="2" Margin="0,16,0,16">
            <TextBlock Text="バックアップ用URI (otpauth://)" 
                       FontSize="11" 
                       FontWeight="SemiBold"
                       Foreground="#86868B" 
                       Margin="0,0,0,6" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UriTextBox" 
                         Grid.Column="0" 
                         IsReadOnly="True" 
                         Background="#E8E8ED" 
                         BorderThickness="0" 
                         Padding="8,6" 
                         VerticalAlignment="Center"
                         FontSize="12"
                         FontFamily="Consolas"
                         TextWrapping="NoWrap"/>
                <Button Grid.Column="1" 
                        Content="コピー" 
                        Click="CopyButton_Click" 
                        Margin="8,0,0,0" 
                        Padding="12,6" 
                        Background="#0071E3" 
                        Foreground="White" 
                        FontWeight="SemiBold"
                        BorderThickness="0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </StackPanel>

        <!-- Close Button -->
        <Button Grid.Row="3" 
                Content="閉じる" 
                Click="CloseButton_Click" 
                Padding="0,8" 
                Background="#E8E8ED" 
                Foreground="#1D1D1F" 
                FontWeight="SemiBold"
                BorderThickness="0">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="6"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>
